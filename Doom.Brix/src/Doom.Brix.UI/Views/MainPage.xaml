<Page
    x:Class="Doom.Brix.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Doom.Brix.ViewModels"
    FontFamily="{StaticResource OpenSansFont}"
    Background="#FF120F0C">

    <Page.DataContext>
        <vm:MainViewModel />
    </Page.DataContext>

    <Grid>

        <!-- ============================ ASSETS MODE ============================ -->
        <Grid Visibility="{Binding AssetsModeVisibility}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header band: black metal with the blood-red rule -->
            <Border Grid.Row="0" Background="#FF1E1712"
                    BorderBrush="#FFC21807" BorderThickness="0,0,0,3"
                    Padding="20,14,20,12">
                <StackPanel>
                    <TextBlock Text="DOOM.BRIX"
                               FontSize="38" FontWeight="Black" CharacterSpacing="150"
                               Foreground="#FFC21807" />
                    <TextBlock Text="ASSETS MODE — SHAREWARE EPISODE SETUP"
                               FontSize="13" FontWeight="SemiBold" CharacterSpacing="220"
                               Foreground="#FFB5A585" Margin="2,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Assets folder bar -->
            <Border Grid.Row="1" Background="#FF241D16"
                    BorderBrush="#FF4A3B2C" BorderThickness="0,0,0,1"
                    Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ASSET FOLDER:"
                               FontWeight="Bold" Foreground="#FFE8DCC0"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Grid.Column="1" HorizontalAlignment="Left" MaxWidth="700" Height="36"
                            Background="#FF3A2C1F" Foreground="#FFF0E6D2"
                            BorderBrush="#FFC21807" BorderThickness="2"
                            Content="{Binding AssetsFolderLabel}"
                            Command="{Binding PickFolderCommand}" />
                </Grid>
            </Border>

            <!-- Content area -->
            <Grid Grid.Row="2">

                <!-- Folder setup (no folder chosen yet) -->
                <Border Visibility="{Binding FolderSetupVisibility}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#FF241D16" BorderBrush="#FFC21807" BorderThickness="2"
                        MaxWidth="620" Padding="32,28">
                    <StackPanel>
                        <TextBlock Text="SELECT YOUR ASSETS FOLDER"
                                   FontSize="22" FontWeight="Black" CharacterSpacing="120"
                                   Foreground="#FFC21807" HorizontalAlignment="Center" />
                        <TextBlock Margin="0,14,0,22" TextWrapping="Wrap" FontSize="15"
                                   Foreground="#FFE8DCC0" TextAlignment="Center"
                                   Text="Doom.Brix needs a folder to keep the DOOM shareware game assets (DOOM1.WAD). Choose where those files should live — your choice is remembered between sessions." />
                        <Button HorizontalAlignment="Center" Height="44" Padding="24,0" FontWeight="Bold"
                                Background="#FF3A2C1F" Foreground="#FFF0E6D2"
                                BorderBrush="#FFC21807" BorderThickness="2"
                                Content="CHOOSE ASSETS FOLDER…"
                                Command="{Binding PickFolderCommand}" />
                    </StackPanel>
                </Border>

                <!-- Browser area (folder chosen: go get doom19s.zip) -->
                <Grid Visibility="{Binding BrowserAreaVisibility}" Margin="20,12,20,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF2A1C10"
                            BorderBrush="#FFFFB000" BorderThickness="1"
                            Padding="12,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" Foreground="#FFFFB000" FontSize="14"
                                   Text="HINT: Download the file doom19s.zip using one of the “Download mirrors:” links on this page." />
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AddressBox" Grid.Column="0" Height="38"
                                 VerticalAlignment="Center" VerticalContentAlignment="Center"
                                 Background="#FF241D16" Foreground="#FFF0E6D2" BorderBrush="#FF4A3B2C"
                                 KeyDown="AddressBox_KeyDown"
                                 Text="{Binding AddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Width="80" Height="38" Margin="10,0,0,0" FontWeight="Bold"
                                Background="#FF3A2C1F" Foreground="#FFF0E6D2"
                                BorderBrush="#FFC21807" BorderThickness="2"
                                Content="GO" Command="{Binding GoCommand}" />
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="#FF4A3B2C" BorderThickness="1">
                        <WebView2 x:Name="Browser" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ============================= GAME MODE ============================= -->
        <Grid Visibility="{Binding GameModeVisibility}" Background="#FF0A0806">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#FF1E1712" BorderBrush="#FFC21807" BorderThickness="3"
                    Padding="48,36">
                <StackPanel>
                    <TextBlock Text="Doom.Brix Game Mode"
                               FontSize="44" FontWeight="Black"
                               Foreground="#FFC21807" HorizontalAlignment="Center" />
                    <TextBlock Text="KNEE-DEEP IN THE DEAD — COMING SOON"
                               FontSize="13" FontWeight="SemiBold" CharacterSpacing="220"
                               Foreground="#FFFFB000" HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Download/verify/extract progress overlay (topmost) -->
        <Grid Visibility="{Binding DownloadOverlayVisibility}" Background="#E0000000">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#FF1E1712" BorderBrush="#FFC21807" BorderThickness="2"
                    Padding="36,28" MinWidth="480">
                <StackPanel>
                    <TextBlock Text="{Binding DownloadStageText}"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="#FFE8DCC0" HorizontalAlignment="Center" />
                    <ProgressBar Margin="0,18,0,8" Height="20" Minimum="0" Maximum="100"
                                 Foreground="#FFC21807" Background="#FF3A2C1F"
                                 Value="{Binding DownloadProgress}" />
                    <TextBlock Text="{Binding DownloadProgressText}"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#FFFFB000" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>
